{% if order.status == 'active' %}
{% set server = service.server %}
{% set hp = service.hosting_plan %}
{% set is_blueonyx = server.manager|default('') == 'Blueonyx' or server.cpanel_url|default('') matches '/:81\\/?$/' %}
<div class="card mb-4">
    <div class="card-header">
        <h2>{{ 'Manage Hosting Account'|trans }}</h2>
    </div>
    <div class="card-body">
        <ul class="nav nav-tabs mb-2">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#details">{{ 'Details'|trans }}</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#password">{{ 'Password'|trans }}</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#domain">{{ 'Domain'|trans }}</a>
            </li>
            {% if not is_blueonyx %}
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#username">{{ 'Username'|trans }}</a>
            </li>
            {% endif %}
        </ul>
        <div class="tab-content">
            <div class="tab-pane fade active show" role="tabpanel" id="details">
                <h3>{{ 'Details'|trans }}</h3>
                <table class="table table-striped table-bordered table-sm">
                    <tbody>
                        <tr>
                            <td>{{ 'Domain'|trans }}:</td>
                            <td>
                                <a target="_blank" href="http://{{ service.domain }}">{{ service.domain }}</a>
                            </td>
                        </tr>
                        <tr>
                            <td>{{ 'Server IP'|trans }}:</td>
                            <td>{{ server.ip }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'Server Hostname'|trans }}:</td>
                            <td>{{ server.hostname }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'Username'|trans }}:</td>
                            <td>{{ service.username }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'Password'|trans }}:</td>
                            <td>******</td>
                        </tr>
                        <tr>
                            <td>{{ 'Hosting Plan'|trans }}:</td>
                            <td>{{ hp.name }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'Bandwidth'|trans }}:</td>
                            <td>{{ hp.bandwidth }} MB / {{ 'per month'|trans }}</td>
                        </tr>
                        <tr>
                            <td>{{ 'Disk Quota'|trans }}:</td>
                            <td>{{ hp.quota }} MB</td>
                        </tr>
                    </tbody>
                </table>
                <div class="control-group">
                    <div class="controls">
                        {% if service.domain_order_id %}
                            <a class="btn btn-primary" href='{{ "order/service/manage/#{service.domain_order_id}"|url }}'>{{ 'Manage Domain'|trans }}</a>
                        {% endif %}
                        <a class="btn btn-primary" href="{{ 'servicehosting/get_login_url'|api_url(query: { 'order_id':  order.id }) }}" {{ fb_api_link({callback: 'onAfterLoginLinkCreated'}) }}>{{ 'Login to Control Panel'|trans }}</a>
                    </div>
                </div>
                {% if is_blueonyx %}
                <div class="card mt-4">
                    <div class="card-body">
                        <h3 class="h5 mb-3">{{ 'SSL status'|trans }}</h3>
                        <div class="mb-3">
                            <div class="small text-secondary">{{ 'Current SSL state'|trans }}</div>
                            <div id="blueonyx-ssl-status" class="fw-semibold">{{ 'Loading…'|trans }}</div>
                        </div>
                        <form method="post" action="{{ 'blueonyx/request_lets_encrypt'|api_url }}" {{ fb_api_form({message: 'SSL certificate request submitted.'|trans, timeoutMs: 300000}) }}>
                            <input type="hidden" name="order_id" value="{{ order.id }}">
                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                <button class="btn btn-outline-primary" type="submit">{{ 'Request Let\'s Encrypt certificate'|trans }}</button>
                                <span class="small text-secondary">{{ 'This submits an API request to BlueOnyx to issue or refresh the certificate.'|trans }}</span>
                            </div>
                        </form>
                    </div>
                </div>
                {% endif %}
            </div>
            <div class="tab-pane fade" role="tabpanel" id="password">
                <h3>{{ 'Change Your Control Panel/FTP/SSH Password'|trans }}</h3>
                <form action="{{ 'servicehosting/change_password'|api_url }}" method="post" {{ fb_api_form({message: 'Password Changed'|trans}) }}>
                    <fieldset>
                        <div class="control-group">
                            <label class="col-form-label" >{{ 'Password'|trans }}: </label>
                            <div class="controls">
                                <input class="form-control" type="password" name="password" value="{{ request.password }}" required="required">
                            </div>
                        </div>
                        <div class="control-group">
                            <label class="col-form-label" >{{ 'Password Confirm'|trans }}: </label>
                            <div class="controls">
                                <input class="form-control" type="password" name="password_confirm" value="{{ request.password_confirm }}" required="required">
                            </div>
                        </div>
                        <input type="hidden" name="order_id" value="{{ order.id }}">
                        <div class="control-group mt-1">
                            <div class="controls">
                                <button class="btn btn-primary" type="submit" value="{{ 'Change Password'|trans }}">{{ 'Change Password'|trans }}</button>
                            </div>
                        </div>
                    </fieldset>
                </form>
            </div>
            <div class="tab-pane fade" role="tabpanel" id="domain">
                <h3>{{ 'Change Domain'|trans }}</h3>
                <form action="{{ 'servicehosting/change_domain'|api_url }}" method="post" {{ fb_api_form({message: 'Domain Name Changed'|trans}) }}>
                    <fieldset>
                        <div class="control-group">
                            <label class="col-form-label" >{{ 'New Domain'|trans }}: </label>
                            <div class="controls row">
                                <input class="form-control w-50 ms-2" type="text" name="sld" value="{{ request.domain|default(service.sld) }}" required="required" class="span2">
                                <input class="form-control w-25" type="text" name="tld" value="{{ request.domain|default(service.tld) }}" required="required" class="span1">
                            </div>
                        </div>
                        <input type="hidden" name="order_id" value="{{ order.id }}">
                        <div class="control-group mt-1">
                            <div class="controls">
                                <button class="btn btn-primary" type="submit" value="{{ 'Change Domain'|trans }}">{{ 'Change Domain'|trans }}</button>
                            </div>
                        </div>
                    </fieldset>
                </form>
            </div>
            {% if not is_blueonyx %}
            <div class="tab-pane fade" role="tabpanel" id="username">
                <h3>{{ 'Change Username'|trans }}</h3>
                <form method="post" action="{{ 'servicehosting/change_username'|api_url }}" {{ fb_api_form({message: 'Username Changed'|trans}) }}>
                    <fieldset>
                        <div class="control-group">
                            <label class="col-form-label" >{{ 'Username'|trans }}: </label>
                            <div class="controls">
                                <input class="form-control" type="text" name="username" value="{{ request.username|default(service.username) }}" required="required">
                            </div>
                        </div>

                        <input type="hidden" name="order_id" value="{{ order.id }}">
                        <div class="control-group mt-1">
                            <div class="controls">
                                <button class="btn btn-primary" type="submit" value="{{ 'Change Username'|trans }}">{{ 'Change Username'|trans }}</button>
                            </div>
                        </div>
                    </fieldset>
                </form>
            </div>
            {% endif %}
        </div>
    </div>
</div>

{% block js %}
<script>
    function onAfterLoginLinkCreated(url){
        window.open(url, "_blank");
    }

    {% if is_blueonyx %}
    document.addEventListener('DOMContentLoaded', async () => {
        const statusNode = document.getElementById('blueonyx-ssl-status');
        if (!statusNode) {
            return;
        }

        try {
            const response = await fetch('{{ "blueonyx/ssl_status"|api_url(query: { "order_id": order.id }) }}', { credentials: 'same-origin' });
            const payload = await response.json();
            const data = payload?.result ?? null;

            if (!data) {
                statusNode.textContent = '{{ 'No SSL data available'|trans }}';
                return;
            }

            const state = data.enabled ? '{{ 'Enabled'|trans }}' : '{{ 'Disabled'|trans }}';
            const issuer = data.issuer ? `, ${data.issuer}` : '';
            const expires = data.expires ? `, ${data.expires}` : '';
            const le = data.uses_letsencrypt ? " (Let's Encrypt)" : '';
            statusNode.textContent = `${state}${le}${issuer}${expires}`;
        } catch (error) {
            statusNode.textContent = '{{ 'Unable to load SSL status'|trans }}';
        }
    });
    {% endif %}
</script>
{% endblock %}
{% endif %}
