<base href="{{ theme.url }}"/>

{% set pending_messages = guest.system_get_pending_messages %}
{% if pending_messages %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    {% for message in pending_messages %}
    if (typeof FOSSBilling !== 'undefined' && FOSSBilling.message) {
        FOSSBilling.message({{ message|json_encode|raw }}, 'success');
    }
    {% endfor %}
});
</script>
{% endif %}
